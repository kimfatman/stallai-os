// Prisma Schema for StallAI Backend
// 摆摊AI经营OS 数据库模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  name          String
  avatar        String?
  level         String   @default("bronze") // bronze, silver, gold
  totalOrders   Int      @default(0)
  totalRevenue  Float    @default(0)
  totalCustomers Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联关系
  products      Product[]
  transactions Transaction[]
  inventory     Inventory[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  favoriteSuppliers FavoriteSupplier[]

  @@map("users")
}

// 商品模型
model Product {
  id                 String   @id @default(uuid())
  userId             String
  name               String
  category           String
  description        String?
  image              String?
  price              Float
  cost               Float
  stock              Int      @default(0)
  lowStockThreshold  Int      @default(10)
  status             String   @default("active") // active, inactive
  totalSold          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // 关联关系
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory     Inventory[]
  transactions  Transaction[]

  @@index([userId])
  @@index([category])
  @@map("products")
}

// 库存模型
model Inventory {
  id              String   @id @default(uuid())
  userId          String
  productId       String
  quantity        Int
  status          String   @default("normal") // normal, low, out
  lastRestockDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 关联关系
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("inventories")
}

// 交易记录模型
model Transaction {
  id          String   @id @default(uuid())
  userId      String
  productId   String?
  type        String   // income, expense
  amount      Float
  category    String?
  description String?
  createdAt   DateTime @default(now())

  // 关联关系
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

// 供应商模型
model Supplier {
  id              String   @id @default(uuid())
  name            String
  category        String
  phone           String?
  address         String?
  rating          Float   @default(5.0)
  verified        Boolean @default(false)
  productCount    Int     @default(0)
  minOrder        Float   @default(0)
  deliveryDays    String  @default("1-3")
  ordersServed    Int     @default(0)
  reviewCount     Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 关联关系
  products   SupplierProduct[]
  reviews    SupplierReview[]
  favorites  FavoriteSupplier[]

  @@index([category])
  @@map("suppliers")
}

// 供应商商品模型
model SupplierProduct {
  id          String   @id @default(uuid())
  supplierId  String
  name        String
  category    String
  spec        String?
  price       Float
  image       String?
  createdAt   DateTime @default(now())

  // 关联关系
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_products")
}

// 供应商评价模型
model SupplierReview {
  id         String   @id @default(uuid())
  supplierId String
  userId     String
  userName   String
  rating     Float
  content    String
  createdAt  DateTime @default(now())

  // 关联关系
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_reviews")
}

// 收藏供应商
model FavoriteSupplier {
  id         String   @id @default(uuid())
  userId     String
  supplierId String
  createdAt  DateTime @default(now())

  // 关联关系
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([userId, supplierId])
  @@map("favorite_suppliers")
}

// 社区帖子模型
model Post {
  id         String   @id @default(uuid())
  userId     String
  category   String   // experience, help, trade, announcement
  title      String
  content    String
  images     String[]
  likes      Int      @default(0)
  comments   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联关系
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentList Comment[]
  likeList    Like[]

  @@index([userId])
  @@index([category])
  @@map("posts")
}

// 评论模型
model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  // 关联关系
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// 点赞模型
model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  // 关联关系
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

// AI 分析记录模型
model AIAnalysis {
  id         String   @id @default(uuid())
  userId     String
  type       String   // insights, selection, prediction
  content    Json
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("ai_analyses")
}

// AI 每日报告模型
model DailyReport {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @db.Date
  healthScore Int
  summary    String
  metrics    Json
  insights   Json
  recommendations Json
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_reports")
}
