{
  "name": "stallai-os",
  "version": "1.0.0",
  "private": true,
  "description": "摆摊AI经营OS - AI Street Vendor Management Operating System",
  "workspaces": [
    "stallai-app",
    "stallai-backend"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r run:dev",
    "build": "pnpm -r run:build",
    "lint": "pnpm -r run:lint",
    "test": "pnpm -r run:test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "pnpm --filter stallai-backend prisma:migrate",
    "db:seed": "pnpm --filter stallai-backend prisma:seed",
    "db:studio": "pnpm --filter stallai-backend prisma:studio"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
